{
  "version": "2.0",
  "description": "RTL 实现流程阶段注册表 — 每个 stage 定义 skill/inputs/outputs/gate/next/on_failure",
  "agent": "chip-code-writer",

  "global_rules": {
    "architecture_frozen": true,
    "coding_style": ".claude/rules/coding-style.md",
    "quality_checklist": ".claude/shared/quality-checklist-impl.md",
    "mandatory_gates": ["lint", "synthesis", "self_check"],
    "gate_skip_allowed": false,
    "gate_degrade_allowed": false
  },

  "stages": [
    {
      "id": "input_triage",
      "name": "输入确认",
      "skill": "chip-impl-input-triage",
      "required_inputs": [
        { "id": "microarch_doc", "name": "微架构文档", "type": "file_path", "priority": "Must", "on_missing": "pause" },
        { "id": "coding_style", "name": "编码规范", "type": "file_path", "priority": "Must", "default": ".claude/rules/coding-style.md" },
        { "id": "cbb_list", "name": "CBB 清单", "type": "file_path", "priority": "Should", "on_missing": "wiki_retrieval" },
        { "id": "protocol_docs", "name": "接口协议文档", "type": "file_path", "priority": "Should", "on_missing": "wiki_retrieval" },
        { "id": "constraints", "name": "关键约束", "type": "object", "priority": "Must", "on_missing": "extract_from_microarch" }
      ],
      "outputs": [
        { "id": "input_status", "type": "string", "values": ["complete", "partial", "vague"] },
        { "id": "missing_items", "type": "array", "item_type": "string" }
      ],
      "gate": "all Must inputs present",
      "next": "wiki_retrieval",
      "on_failure": "pause"
    },

    {
      "id": "wiki_retrieval",
      "name": "Wiki 检索",
      "skill": "wiki-query",
      "description": "检索 CBB 文档和协议文档，获取标准实例化示例",
      "inputs": [
        { "id": "cbb_list", "type": "file_path" },
        { "id": "protocol_docs", "type": "file_path" }
      ],
      "outputs": [
        { "id": "cbb_docs", "type": "array", "item_type": "file_path" },
        { "id": "protocol_docs_resolved", "type": "array", "item_type": "file_path" }
      ],
      "gate": "cbb_docs 非空或已标注 [CBB-MISSING]",
      "next": "module_structure",
      "on_failure": "degrade",
      "degrade_action": "标注 [CBB-MISSING]，基于通用知识继续"
    },

    {
      "id": "module_structure",
      "name": "模块结构规划",
      "skill": "chip-impl-module-structure",
      "description": "从微架构提取端口列表、子模块划分、文件清单",
      "inputs": [
        { "id": "microarch_doc", "type": "file_path" },
        { "id": "cbb_docs", "type": "array", "item_type": "file_path" }
      ],
      "outputs": [
        { "id": "port_list", "type": "array", "item_type": "object" },
        { "id": "submodule_list", "type": "array", "item_type": "object" },
        { "id": "file_list", "type": "array", "item_type": "file_path" },
        { "id": "work_dir", "type": "file_path" }
      ],
      "gate": "port list matches microarch §4.1",
      "next": "rtl_impl",
      "on_failure": "pause"
    },

    {
      "id": "rtl_impl",
      "name": "RTL 代码实现",
      "skill": "chip-impl-rtl-coding",
      "description": "逐子模块实现数据通路+控制逻辑+CBB+接口",
      "inputs": [
        { "id": "microarch_doc", "type": "file_path" },
        { "id": "port_list", "type": "array", "item_type": "object" },
        { "id": "submodule_list", "type": "array", "item_type": "object" },
        { "id": "cbb_docs", "type": "array", "item_type": "file_path" },
        { "id": "coding_style", "type": "file_path" }
      ],
      "outputs": [
        { "id": "rtl_files", "type": "array", "item_type": "file_path" }
      ],
      "per_submodule": true,
      "gate": "each submodule RTL compiles without syntax errors",
      "next": "sdc_sva_scripts",
      "on_failure": "pause"
    },

    {
      "id": "sdc_sva_scripts",
      "name": "SVA + Run 脚本生成",
      "skill": "chip-impl-sdc-sva",
      "description": "生成 SVA 断言 + run 目录脚本（.f / .sdc / lint.sh / synth_yosys.tcl）",
      "inputs": [
        { "id": "rtl_files", "type": "array", "item_type": "file_path" },
        { "id": "microarch_doc", "type": "file_path" },
        { "id": "port_list", "type": "array", "item_type": "object" }
      ],
      "outputs": [
        { "id": "sva_file", "type": "file_path" },
        { "id": "filelist", "type": "file_path", "path": "{work_dir}/run/{module}.f" },
        { "id": "sdc_file", "type": "file_path", "path": "{work_dir}/run/{module}.sdc" },
        { "id": "lint_script", "type": "file_path", "path": "{work_dir}/run/lint.sh" },
        { "id": "synth_script", "type": "file_path", "path": "{work_dir}/run/synth_yosys.tcl" }
      ],
      "gate": "all 5 files generated",
      "next": "quality_check",
      "on_failure": "pause"
    },

    {
      "id": "quality_check",
      "name": "质量门禁（Lint + 综合）",
      "skill": "chip-impl-quality-gate",
      "description": "执行 Lint 检查（Verilator）+ 综合检查（Yosys），不通过进入自愈循环",
      "inline_steps": [
        "mkdir -p {work_dir}/ds/report/lint {work_dir}/ds/report/syn",
        "cd {work_dir}/run && bash lint.sh all 2>&1 | tee ../ds/report/lint/lint_summary.log",
        "检查 lint_summary.log：有 Error → 自愈修复 → 重跑",
        "cd {work_dir}/run && yosys synth_yosys.tcl 2>&1 | tee ../ds/report/syn/synth_summary.log",
        "检查 synth_summary.log：有 ERROR → 自愈修复 → 重跑"
      ],
      "inputs": [
        { "id": "rtl_files", "type": "array", "item_type": "file_path" },
        { "id": "run_scripts", "type": "array", "item_type": "file_path" },
        { "id": "work_dir", "type": "file_path" }
      ],
      "outputs": [
        { "id": "lint_report", "type": "file_path", "path": "{work_dir}/ds/report/lint/lint_summary.log" },
        { "id": "synth_report", "type": "file_path", "path": "{work_dir}/ds/report/syn/synth_summary.log" }
      ],
      "gate": "lint ALL PASS + synth ALL PASS",
      "next": "self_check",
      "on_failure": "self_heal",
      "self_heal": {
        "max_iterations": 10,
        "hard_limit": 30,
        "oscillation_threshold": 3,
        "oscillation_action": "pause_and_rollback",
        "exhausted_action": "force_exit"
      }
    },

    {
      "id": "self_check",
      "name": "自检",
      "skill": "chip-impl-self-check",
      "description": "IC-01~39 + IM-01~08 三阶段自检",
      "inputs": [
        { "id": "rtl_files", "type": "array", "item_type": "file_path" },
        { "id": "lint_report", "type": "file_path" },
        { "id": "synth_report", "type": "file_path" },
        { "id": "microarch_doc", "type": "file_path" }
      ],
      "outputs": [
        { "id": "self_check_report", "type": "file_path" }
      ],
      "gate": "IC-01~39 + IM-01~08 all pass",
      "next": "delivery",
      "on_failure": "self_heal",
      "self_heal": {
        "max_iterations": 5,
        "action": "fix_and_recheck"
      }
    },

    {
      "id": "delivery",
      "name": "交付",
      "skill": "chip-impl-delivery",
      "description": "验证交付物完整性，输出清单",
      "inputs": [
        { "id": "all_outputs", "type": "object", "description": "所有上游 stage 的 outputs 汇总" },
        { "id": "work_dir", "type": "file_path" }
      ],
      "outputs": [
        { "id": "delivery_manifest", "type": "file_path" }
      ],
      "deliverables": [
        "RTL 源码 .v",
        "CBB 清单 _cbb_list.md",
        "SDC .sdc",
        "SVA _sva.sv",
        "Interface _intf.sv（如需）",
        "UPF .upf（如需）",
        "TB _tb.v（如需）",
        "Makefile/Lint/综合脚本",
        "Lint 报告 lint_summary.log",
        "综合报告 synth_summary.log"
      ],
      "gate": "all 10 deliverables present",
      "next": null,
      "on_failure": "pause"
    }
  ],

  "parallel_dev": {
    "skill": "chip-impl-parallel-dev",
    "description": "多模块并行开发流程",
    "phases": [
      { "id": "plan_mode", "name": "Plan Mode 分析", "skill": "chip-impl-parallel-dev" },
      { "id": "parallel_impl", "name": "并行 Subagent 开发", "skill": "chip-impl-parallel-dev" },
      { "id": "top_integration", "name": "顶层集成", "skill": "chip-impl-parallel-dev" },
      { "id": "pr_confirm", "name": "PR/FS/UA 确认", "skill": "chip-impl-parallel-dev" }
    ]
  },

  "todo_mechanism": {
    "source": ".claude/shared/todo-mechanism.md",
    "inlined_in_agent": true,
    "modes": ["step", "continuous"],
    "default_mode": "continuous",
    "pause_rules": ["cbb_missing", "arch_question", "scope_change", "gate_failure"]
  }
}
