  "hot_reload_protocol": {
    "description": "文件变更后仅重载该文件及其反向依赖，无需重启会话",
    "steps": [
      "1. 检测到某文件变更（用户通知或 version 字段变化）",
      "2. 查 registry 获取该文件的 dependents（直接依赖它的文件）",
      "3. 重载变更文件",
      "4. 校验 dependents 中的引用是否仍然有效",
      "5. 若 dependents 引用断裂 → 列出断裂项，暂停等待修复",
      "6. 若无断裂 → 热加载完成，继续当前阶段"
    ],
    "no_reload_needed": ["stage 间切换时自动 Read 对应 L2 文件，无需主动热加载", "L3 临时文件用完即弃，不参与热加载"]
  }
}
